# Настройки для Telegram-уведомлений об изменении цен
# Скопируйте этот файл как .env и заполните своими значениями

# Токен вашего Telegram-бота (получается у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш Chat ID или ID группы (куда бот будет присылать уведомления). 
# Узнать свой ID можно через ботов @userinfobot или @GetMyChatID_Bot
TELEGRAM_CHAT_ID=your_chat_id_here
